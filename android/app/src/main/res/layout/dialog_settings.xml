<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="服务器设置"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="服务器地址" />

    <EditText
        android:id="@+id/serverUrlInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="http://192.168.x.x:8000"
        android:inputType="textUri"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="画框展示阈值 (0~1，建议 0.5~0.6)" />

    <EditText
        android:id="@+id/displayConfInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="0.50"
        android:inputType="numberDecimal"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="上报阈值 (0~1，建议 0.7~0.85)" />

    <EditText
        android:id="@+id/reportConfInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="0.70"
        android:inputType="numberDecimal"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="提示：本地测试请使用电脑局域网IP"
        android:textSize="12sp"
        android:textColor="#666666" />

</LinearLayout>