<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="巡查工作台"
                android:textSize="14sp"
                android:textColor="#8C8C8C" />

            <TextView
                android:id="@+id/welcomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="欢迎"
                android:textSize="24sp"
                android:textColor="#262626"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <Button
                android:id="@+id/startInspectionBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="开始巡查"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:background="#1677FF" />

            <Button
                android:id="@+id/myReportsBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:text="我的上报"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:background="#389E0D" />

            <Button
                android:id="@+id/trackHistoryBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="历史轨迹"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:background="#531DAB" />

            <Button
                android:id="@+id/userSettingsBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="用户设置"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:background="#D89614" />
        </LinearLayout>

        <Button
            android:id="@+id/logoutBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:text="退出登录"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:background="#CF1322" />
    </LinearLayout>
</ScrollView>